<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/outerWrapper"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <FrameLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <FrameLayout
            android:id="@+id/slotA"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000" />

        <FrameLayout
            android:id="@+id/slotB"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000"
            android:alpha="0" />

        <FrameLayout
            android:id="@+id/widgetsLayer"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/topRightWidget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="20dp"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/offlineBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● OFFLINE"
                    android:textColor="#EF4444"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="#CC000000"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/clockTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/clockDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--/--"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/orgLogo"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="20dp"
                android:scaleType="fitEnd"
                android:adjustViewBounds="true"
                android:visibility="gone" />

        </FrameLayout>

        <LinearLayout
            android:id="@+id/loadingScreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#000000"
            android:visibility="visible">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminate="true"
                android:indeterminateTint="#1EAF6A" />

            <TextView
                android:id="@+id/loadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Iniciando Loopin TV..."
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <TextView
                android:id="@+id/loadingSubtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/setupScreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#111111"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOOPIN TV"
                android:textColor="#1EAF6A"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acesse o painel e cadastre este código:"
                android:textColor="#A0AEC0"
                android:textSize="14sp"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/pairingCodeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="----"
                android:textColor="#FFFFFF"
                android:textSize="56sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp"
                android:background="@drawable/pairing_code_bg" />

            <Button
                android:id="@+id/btnRefreshCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄 Gerar Novo Código"
                android:layout_marginTop="24dp"
                android:backgroundTint="#2D3748"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aguardando vinculação..."
                android:textColor="#4A5568"
                android:textSize="12sp"
                android:layout_marginTop="16dp" />
        </LinearLayout>

    </FrameLayout>

</FrameLayout>